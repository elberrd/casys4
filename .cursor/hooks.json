{
  "version": 1,
  "hooks": {
    "beforeShellExecution": [
      {
        "command": ".cursor/hooks/validate-pnpm.sh",
        "matcher": "^(npm|npx|yarn|yarnpkg)\\b",
        "failClosed": true
      }
    ],
    "stop": [
      {
        "command": ".cursor/hooks/senior-dev-chain.sh",
        "loop_limit": 2
      }
    ]
  }
}
